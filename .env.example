VITE_RETRIEVAL_MODE=local_mock
VITE_RETRIEVAL_API_URL=http://localhost:8787/api/retrieve-policy-evidence

# Server-only Foundry IQ settings. Do not prefix these with VITE_.
FOUNDRY_IQ_SEARCH_ENDPOINT=
FOUNDRY_IQ_KNOWLEDGE_BASE=
FOUNDRY_IQ_KNOWLEDGE_SOURCE_NAME=
FOUNDRY_IQ_API_VERSION=2026-05-01-preview
FOUNDRY_IQ_MAX_OUTPUT_TOKENS=1400
FOUNDRY_IQ_MAX_RUNTIME_SECONDS=15
FOUNDRY_IQ_PROXY_PORT=8787

# Optional service-principal auth for DefaultAzureCredential.
# Prefer `az login` for local demos when possible.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
